# Day 8 - LeetCode Practice
# Problem: Binary Search (LeetCode 704)

# Approach:
# - Use low and high pointers
# - Find mid and compare with target
# - Reduce search space by half

# Time Complexity: O(log n)
# Space Complexity: O(1)

# Key Concepts:
# - Binary Search basics
# - Divide and conquer
  class Solution:
    def search(self, nums: List[int], target: int) -> int:
        low=0
        high=len(nums)-1
        while low<=high:
            mid=(low+high)//2
            if nums[mid]==target:
                return mid
            elif nums[mid]<target:
                low=mid+1
            else:
                high=mid-1    

                   
        
