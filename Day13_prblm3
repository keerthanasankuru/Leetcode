"""
Problem: Balanced Binary Tree

Description:
Given a binary tree, determine if it is height-balanced.
A tree is balanced if for every node:
|left_height - right_height| <= 1

Approach:
- Use DFS to calculate height
- If any subtree is unbalanced → return -1
- Avoid repeated height calculation

Time Complexity: O(n)
Space Complexity: O(h)
"""

class Solution:
    def isBalanced(self, root):

        def dfs(node):
            if not node:
                return 0
            
            left = dfs(node.left)
            if left == -1:
                return -1

            right = dfs(node.right)
            if right == -1:
                return -1

            if abs(left - right) > 1:
                return -1

            return 1 + max(left, right)

        return dfs(root) != -1
