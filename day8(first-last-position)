# Day 8 - LeetCode Practice
# Problem: Find First and Last Position (LeetCode 34)

# Approach:
# - Use binary search twice
#   → find first occurrence
#   → find last occurrence

# Time Complexity: O(log n)
# Space Complexity: O(1)

# Key Concepts:
# - Modified binary search
# - Boundaries handling
  class Solution:
    def searchRange(self, nums: List[int], target: int) -> List[int]:
        
        def findFirst():
            low, high = 0, len(nums) - 1
            ans = -1
            while low <= high:
                mid = (low + high) // 2
                if nums[mid] == target:
                    ans = mid
                    high = mid - 1   
                elif nums[mid] < target:
                    low = mid + 1
                else:
                    high = mid - 1
            return ans
        
        def findLast():
            low, high = 0, len(nums) - 1
            ans = -1
            while low <= high:
                mid = (low + high) // 2
                if nums[mid] == target:
                    ans = mid
                    low = mid + 1   
                elif nums[mid] < target:
                    low = mid + 1
                else:
                    high = mid - 1
            return ans
        
        return [findFirst(), findLast()]
