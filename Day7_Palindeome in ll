# Day 7- LeetCode Practice
# Problem: Palindrome Linked List (LeetCode 234)
# Link: https://leetcode.com/problems/palindrome-linked-list/

# Approach:
# - Use slow & fast pointer to find middle
# - Reverse second half of list
# - Compare both halves

# Time Complexity: O(n)
# Space Complexity: O(1)

# Key Concepts:
# - Two pointers
# - Linked list reversal
# - Comparison logic
class Solution:
    def isPalindrome(self, head):
        slow=fast=head
        while fast and fast.next:
            slow=slow.next
            fast=fast.next.next
        

        temp=slow
        prev=None
        while temp:
            front=temp.next
            temp.next=prev
            prev=temp
            temp=front
        
        
        left=head
        right=prev
        while right:
            if left.val!=right.val:
                return False
            left=left.next
            right=right.next
        return True        


        

